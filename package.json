{
  "name": "clever-print",
  "version": "0.1.4",
  "description": "Clever ERP — Local print agent. Receives receipt JSON over loopback HTTP and prints ESC/POS to a thermal printer.",
  "private": true,
  "main": "out/main/index.js",
  "packageManager": "pnpm@10.24.0",
  "author": "Clever ERP",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts,tsx",
    "postinstall": "electron-builder install-app-deps",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win",
    "publish": "pnpm build && electron-builder --publish always"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "usb"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "electron-log": "^5.2.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "hono": "^4.6.10",
    "node-thermal-printer": "^4.5.0",
    "qrcode": "^1.5.4",
    "usb": "^2.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^31.7.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.5.4",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
